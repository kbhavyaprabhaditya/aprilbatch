# ============================================================
# Stage 1 – BUILD
# Use Maven + JDK 11 to compile the project and package the JAR
# ============================================================
FROM maven:3.9.6-eclipse-temurin-11 AS build

WORKDIR /app

# Copy dependency manifest first (layer-cache friendly)
COPY pom.xml .

# Download dependencies only (cached unless pom.xml changes)
RUN mvn dependency:go-offline -q

# Copy the full source
COPY src ./src

# Compile and package (skip tests during image build)
RUN mvn clean package -DskipTests -q

# ============================================================
# Stage 2 – RUN
# Use a slim JRE-only image to run the packaged JAR
# ============================================================
FROM eclipse-temurin:11-jre-alpine AS runtime

LABEL maintainer="bhavyaprabhaditya"
LABEL description="Java HTTP Web Server – Assignment 1"
LABEL version="v1"

WORKDIR /app

# Copy only the JAR from the build stage
COPY --from=build /app/target/java-web-app.jar java-web-app.jar

# Expose the application port
EXPOSE 9090

# Run the web server
ENTRYPOINT ["java", "-jar", "java-web-app.jar"]